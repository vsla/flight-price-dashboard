# Banco de dados (Docker local)
DATABASE_URL=postgresql://postgres:flighttracker@localhost:5432/flights

# Aviasales / Travelpayouts (gratuita)
# Registro: https://travelpayouts.com/
AVIASALES_TOKEN=

# SerpAPI — Google Flights (gratuita, 250 queries/mês)
# Registro: https://serpapi.com/
SERPAPI_KEY=

# Amadeus for Developers (gratuita - usar PRODUÇÃO, não sandbox)
# Registro: https://developers.amadeus.com/
# IMPORTANTE: solicitar acesso Self-Service Production após criar conta
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
